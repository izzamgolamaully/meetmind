# =============================================
# MeetMind — Environment Variables
# Copy to .env.local and fill in your values
# =============================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# Database (PostgreSQL via Supabase / Neon / Railway)
DATABASE_URL=postgresql://user:password@host:5432/meetmind

# OAuth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe dashboard)
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# AI — OpenAI (for Whisper transcription + GPT summaries)
OPENAI_API_KEY=sk-...

# AssemblyAI (alternative transcription with speaker diarisation)
ASSEMBLYAI_API_KEY=your-assemblyai-key

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# File Storage (AWS S3 or Cloudflare R2)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=eu-west-2
AWS_S3_BUCKET=meetmind-recordings

# Integrations (optional)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
LINEAR_API_KEY=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
